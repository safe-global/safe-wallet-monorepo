{
  "name": "@safe-global/web-tanstack",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 3001",
    "serve": "sh -c 'npx -y serve dist -p ${PORT:=3001}'",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "eslint": "eslint",
    "prettier": "prettier --check . --config ../../.prettierrc --ignore-path ../../.prettierignore",
    "prettier:fix": "prettier --write . --config ../../.prettierrc --ignore-path ../../.prettierignore",
    "test": "cross-env TZ=UTC NODE_ENV=test jest",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage",
    "test:plugins": "node --test \"plugins/**/*.test.ts\"",
    "assert:sri": "node scripts/assert-sri.mjs dist",
    "verify": "node ../../scripts/verify.mjs --workspace=web-tanstack",
    "verify:changed": "node ../../scripts/verify.mjs --changed --workspace=web-tanstack",
    "cypress:open": "cross-env TZ=UTC cypress open --e2e",
    "cypress:run": "cross-env TZ=UTC cypress run",
    "cypress:ci": "cross-env TZ=UTC yarn cypress:run --config baseUrl=http://localhost:3001 --spec cypress/e2e/smoke/*.cy.js"
  },
  "dependencies": {
    "@safe-global/store": "workspace:*",
    "@safe-global/theme": "workspace:*",
    "@safe-global/utils": "workspace:*",
    "@safe-global/web": "workspace:*",
    "@tanstack/react-router": "1.159.4",
    "firebase": "11.1.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-helmet-async": "^3.0.0",
    "react-redux": "^9.1.2"
  },
  "devDependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@safe-global/test": "workspace:*",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-devtools": "1.159.4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "@types/react-dom": "~19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^7.0.3",
    "cypress": "^15.9.0",
    "eslint": "^9.29.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-fixed-jsdom": "^0.0.10",
    "jest-transform-stub": "2.0.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.18",
    "ts-jest": "29.2.5",
    "typescript": "~5.9.2",
    "vite": "8.0.13",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-svgr": "^5.2.0",
    "workbox-cacheable-response": "^7.3.0",
    "workbox-core": "^7.3.0",
    "workbox-expiration": "^7.3.0",
    "workbox-precaching": "^7.3.0",
    "workbox-routing": "^7.3.0",
    "workbox-strategies": "^7.3.0"
  }
}
